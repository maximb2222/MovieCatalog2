<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MovieCatalog.ViewModels"
             xmlns:local="clr-namespace:MovieCatalog"
             x:Class="MovieCatalog.Views.MoviesListPage"
             x:DataType="viewmodels:MovieListViewModel"
             Title="Каталог фильмов">

    <CollectionView ItemsSource="{Binding Movies}" 
                    SelectedItem="{Binding SelectedMovie, Mode=OneWayToSource}"
                    Margin="10" 
                    SelectionMode="Single"
                    SelectionChanged="OnSelectionChanged">

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="viewmodels:MovieViewModel">
                <Grid Padding="10" RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">

                    <Grid Grid.Row="0" Grid.ColumnSpan="2">
                        <Label Text="{Binding Title}" 
                               FontSize="16" 
                               FontAttributes="Bold" />
                        <Label Grid.Row="1" 
                               Text="{Binding Year}" 
                               FontSize="14" 
                               TextColor="Gray" />
                    </Grid>

                    <Button Grid.Row="1" Grid.Column="1"
                            Text="Удалить"
                            BackgroundColor="Red"
                            TextColor="White"
                            WidthRequest="80"
                            HeightRequest="40"
                            Command="{Binding DeleteMovieCommand, Source={x:Static local:App.MainViewModel}}"
                            CommandParameter="{Binding}" />

                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>