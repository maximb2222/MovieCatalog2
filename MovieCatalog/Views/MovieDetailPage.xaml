<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MovieCatalog.ViewModels"
             x:Class="MovieCatalog.Views.MovieDetailPage"
             x:DataType="viewmodels:MovieViewModel"
             Title="О фильме">

    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="{Binding Title}" 
               FontSize="24" 
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label Text="{Binding Year, StringFormat='Год: {0}'}" 
               FontSize="16" />

        <Label Text="{Binding Director, StringFormat='Режиссёр: {0}'}" 
               FontSize="16" />

        <Label Text="{Binding Genre, StringFormat='Жанр: {0}'}" 
               FontSize="16" />

    </VerticalStackLayout>

</ContentPage>